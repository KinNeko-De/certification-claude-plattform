{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug current script",
      "type": "node",
      "request": "launch",
      "program": "${file}",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--import", "tsx"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    },
    {
      "name": "Debug 00-hello-claude",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/00-hello-claude.ts",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--import", "tsx"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    }
  ]
}
